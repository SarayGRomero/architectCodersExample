<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tool="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/item_asteroid_background"
    android:padding="16dp"
    android:layout_marginHorizontal="10dp"
    android:layout_marginTop="10dp">

    <LinearLayout
        android:id="@+id/asteroid_item__ll__info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/asteroid_item__iv__potentially_hazardous_indicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/asteriod_item__tv__name"
            style="@style/Text.Bold.Medium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tool:text="277617 (2006 BT7)" />

        <TextView
            android:id="@+id/asteroid_item__tv__distance"
            style="@style/Text.Regular.Normal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:maxLines="2"
            tool:text="Distancia a La Tierra: 51099724.05980933 Km" />

        <TextView
            style="@style/Text.Regular.Normal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            tool:text="Magnitud: 18.23" />

    </LinearLayout>

    <ImageView
        android:id="@+id/asteroid_item__iv__potentially_hazardous_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_safety"
        android:layout_marginStart="10dp"
        app:layout_constraintStart_toEndOf="@id/asteroid_item__ll__info"
        app:layout_constraintBottom_toBottomOf="@id/asteroid_item__ll__info"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/asteroid_item__ll__info" />
</androidx.constraintlayout.widget.ConstraintLayout>