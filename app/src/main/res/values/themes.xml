<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.AsteroidTracker" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorSecondary">@color/secondary_color</item>
        <item name="colorTertiary">@color/tertiary_color</item>
        <item name="colorAccent">@color/color_accent</item>
    </style>

    <style name="Theme.AsteroidTracker" parent="Base.Theme.AsteroidTracker" />

    <style name="Text">
        <item name="android:textColor">@color/blue_dark</item>
    </style>
    
    <style name="Text.Bold">
        <item name="android:fontFamily">@font/robotobold</item>
    </style>
    
    <style name="Text.Regular">
        <item name="android:fontFamily">@font/robotoregular</item>
    </style>

    <style name="Text.Light">
        <item name="android:fontFamily">@font/robotolight</item>
    </style>

    <style name="Small">
        <item name="android:textSize">@dimen/text_size_small</item>
    </style>

    <style name="Text.Regular.Normal">
        <item name="android:textSize">@dimen/text_size_normal</item>
    </style>

    <style name="Text.Bold.Medium">
        <item name="android:textSize">@dimen/text_size_medium</item>
    </style>

    <style name="Big">
        <item name="android:textSize">@dimen/text_size_big</item>
    </style>
</resources>